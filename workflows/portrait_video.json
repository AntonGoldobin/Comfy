{
  "LoadImage": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{input_image}}"
    }
  },
  "SVD_img2vid_Portrait": {
    "class_type": "SVD_img2vid_Conditioning",
    "inputs": {
      "image": ["LoadImage", 0],
      "strength": 0.9
    }
  },
  "EmptyLatentVideo_Portrait": {
    "class_type": "EmptyLatentVideo",
    "inputs": {
      "width": 512,
      "height": 768,
      "frames": 25,
      "batch_size": 1
    }
  },
  "SVD_Sampler_Portrait": {
    "class_type": "SVD_Sampler",
    "inputs": {
      "seed": "{{seed | default(123)}}",
      "steps": 25,
      "cfg": 6.0,
      "sampler_name": "euler",
      "scheduler": "normal",
      "conditioning": ["SVD_img2vid_Portrait", 0],
      "latent_image": ["EmptyLatentVideo_Portrait", 0]
    }
  },
  "VAEDecode_Portrait": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["SVD_Sampler_Portrait", 0],
      "vae": ["SVD_Load_Portrait", 0]
    }
  },
  "SVD_Load_Portrait": {
    "class_type": "SVD_Load",
    "inputs": {}
  },
  "VHS_VideoCombine_Portrait": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["VAEDecode_Portrait", 0],
      "fps": 24,
      "filename_prefix": "portrait_video",
      "output_dir": "/output"
    }
  }
}
