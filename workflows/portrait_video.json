{
  "3": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{input_image}}"
    }
  },
  "4": {
    "class_type": "SVD_img2vid_Conditioning",
    "inputs": {
      "image": ["3", 0],
      "strength": "{{strength | default(0.9)}}"
    }
  },
  "5": {
    "class_type": "EmptyLatentVideo",
    "inputs": {
      "width": 512,
      "height": 768,
      "frames": "{{frames | default(25)}}",
      "batch_size": 1
    }
  },
  "6": {
    "class_type": "SVD_Sampler",
    "inputs": {
      "seed": "{{seed | default(123)}}",
      "steps": "{{steps | default(25)}}",
      "cfg": "{{cfg | default(6.0)}}",
      "sampler_name": "euler",
      "scheduler": "normal",
      "conditioning": ["4", 0],
      "latent_image": ["5", 0]
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["6", 0],
      "vae": ["8", 0]
    }
  },
  "8": {
    "class_type": "SVD_Load",
    "inputs": {}
  },
  "9": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["7", 0],
      "fps": "{{fps | default(24)}}",
      "filename_prefix": "portrait_video",
      "output_dir": "/output"
    }
  }
}
