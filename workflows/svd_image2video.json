{
  "LoadImage": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{input_image}}"
    }
  },
  "SVD_img2vid_Conditioning": {
    "class_type": "SVD_img2vid_Conditioning",
    "inputs": {
      "image": ["LoadImage", 0],
      "strength": "{{strength | default(1.0)}}"
    }
  },
  "EmptyLatentVideo": {
    "class_type": "EmptyLatentVideo",
    "inputs": {
      "width": "{{width | default(1024)}}",
      "height": "{{height | default(1024)}}",
      "frames": "{{frames | default(25)}}",
      "batch_size": 1
    }
  },
  "SVD_Sampler": {
    "class_type": "SVD_Sampler",
    "inputs": {
      "seed": "{{seed | default(42)}}",
      "steps": "{{steps | default(30)}}",
      "cfg": "{{cfg | default(7.0)}}",
      "sampler_name": "euler",
      "scheduler": "normal",
      "conditioning": ["SVD_img2vid_Conditioning", 0],
      "latent_image": ["EmptyLatentVideo", 0]
    }
  },
  "VAEDecode": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["SVD_Sampler", 0],
      "vae": ["SVD_Load", 0]
    }
  },
  "SVD_Load": {
    "class_type": "SVD_Load",
    "inputs": {}
  },
  "VHS_VideoCombine": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["VAEDecode", 0],
      "fps": "{{fps | default(30)}}",
      "filename_prefix": "svd_video",
      "output_dir": "/output"
    }
  }
}
